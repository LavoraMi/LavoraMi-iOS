    "completamenteAccessibileDeps" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "All vehicles operating on this route are equipped with boarding ramps (manual or electric) and reserved seating. Furthermore, almost all stops (over 90%) have raised platforms, enabling passengers to board independently or with minimal assistance."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Todos los vehículos que circulan por esta línea están equipados con plataformas (manuales o eléctricas) y asientos reservados. Además, casi todas las paradas (más del 90 %) cuentan con andenes elevados que permiten subir al autobús de forma autónoma o con una asistencia mínima."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tutti i mezzi impiegati su questa linea sono dotati di pedane (manuali o elettriche) e posto riservato. Inoltre, la quasi totalità delle fermate (oltre il 90%) dispone di banchine rialzate che permettono l'incarrozzamento in autonomia o con assistenza minima."
          }
        }
      }
    },
