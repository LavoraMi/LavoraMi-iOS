    "personaleDeps" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If your train journey continues by replacement bus, the on-board staff will provide you with all the information you need to continue your journey with peace of mind."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si el trayecto de tu tren continúa en un autobús sustitutivo, el personal de a bordo te proporcionará toda la información necesaria para que puedas continuar tu viaje con tranquilidad."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se il tragitto del tuo treno continua attraverso un bus sostitutivo, il personale di bordo ti darà tutte le informazioni necessarie per continuare il tuo viaggio in tranquillità."
          }
        }
      }
    },
