    },
    "Non hai un account?" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Don’t have an Account?"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿No tienes una cuenta?"
          }
        }
      }
    },
    "Non importa se Suburbano, Metro o Bus, scegli la linea che più ti interessa." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Whether it’s the Suburbano, the Metro or the bus, choose the route that suits you best."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Da igual si es Suburbano, Metro o Autobús, elige la línea que más te interese."
          }
        }
      }
    },
    "Non solo \"lavori in via\", ti spieghiamo che tipo di lavoro si sta svolgendo ed anche le conseguenze che può portare quel cantiere (Deviazioni, Fermate Sospese...)" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Not just “work in progress” we explain what type of work is being done and the consequences that construction site may have (detours, suspended stops, etc)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No solo «obras en la calle»: te explicamos qué tipo de obras se están llevando a cabo y también las consecuencias que puede acarrear esa obra (desvíos, paradas suspendidas...)"
          }
        }
      }
    },
    "nonAccessibileDeps" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This route does not meet the minimum accessibility requirements. There may be steps at the entrance to the vehicle, or the road infrastructure along the route may make it impossible to lower the ramp safely."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esta línea no cumple los requisitos mínimos de accesibilidad. Es posible que los vehículos tengan escalones en la entrada o que las infraestructuras viarias del recorrido impidan bajar la rampa de forma segura."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Questa linea non garantisce i requisiti minimi di accessibilità. I mezzi potrebbero presentare gradini all'ingresso del mezzo oppure le infrastrutture stradali del percorso rendono impossibile la discesa della pedana in sicurezza."
          }
        }
      }
    },
