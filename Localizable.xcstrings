    "Visualizza i percorsi delle linee che preferisci sulla mappa, per non perdersi e per sapere sempre dove vai." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "View the routes of your favorite lines on the map, so you don’t get lost and always know where you are going."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Visualiza los recorridos de las líneas que prefieras en el mapa, para no perderte y saber siempre adónde vas."
          }
        }
      }
    },
    "Visualizza le linee che interscambiano con la TUA linea, oppure sui bus visualizza dove fanno capolinea con una fermata di interscambio." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "View the lines that interchange with YOUR line, or on buses view where they end with a Transfer Stop."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consulta las líneas que hacen transbordo con TU línea, o, en el caso de los autobuses, comprueba dónde terminan su recorrido con una parada de transbordo."
          }
        }
      }
    },
