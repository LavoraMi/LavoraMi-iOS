    },
    "Non hai dato il permesso per ricevere notifiche. Vai su Impostazioni > App > LavoraMi ed attiva le notifiche." : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You haven’t granted LavoraMi permission to send notifications. Go to Settings > Apps > LavoraMi and enable the permission."
          }
        },
        "es" : {
